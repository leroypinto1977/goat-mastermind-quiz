    "legacyOrAlternate": {
      "copper": { "hex": "#b87333", "hoverHex": "#9d5f28" },
      "textDark": { "hex": "#1C1C1C" },
      "textMuted": { "hex": "#5A5A5A" }
    }
  },
  "gradients": {
    "luxury": "linear-gradient(135deg, hsl(210 68% 15%) 0%, hsl(210 68% 25%) 100%)",
    "gold": "linear-gradient(135deg, hsl(43 74% 42%) 0%, hsl(43 74% 52%) 50%, hsl(43 74% 62%) 100%)"
  },
  "shadows": {
    "elegant": "0 4px 20px -8px hsl(210 68% 15% / 0.2)",
    "luxury": "0 8px 40px -12px hsl(210 68% 15% / 0.3)",
    "gold": "0 4px 20px -8px hsl(43 74% 52% / 0.4)"
  },
  "typography": {
    "fontFamilies": {
      "sans": {
        "cssVar": "--font-inter",
        "family": "Inter",
        "fallback": "sans-serif",
        "usage": "Body text, UI"
      },
      "heading": {
        "cssVar": "--font-poppins",
        "family": "Poppins",
        "fallback": "sans-serif",
        "usage": "Headings, display"
      },
      "raleway": {
        "cssVar": "--font-raleway",
        "family": "Raleway",
        "fallback": "sans-serif",
        "usage": "Menu/hero (StaggeredMenu)"
      }
    },
    "weights": {
      "inter": ["300", "400", "500", "600", "700"],
      "poppins": ["300", "400", "500", "600", "700", "800"],
      "raleway": ["400", "500", "600", "700", "800"]
    },
    "defaultBody": "Poppins (body uses Poppins in globals; second layer uses Inter)",
    "utilityClasses": {
      "fontHeading": "Headings use .font-heading (Poppins)",
      "fontSans": "Body/UI use .font-sans (Inter)"
    },
    "rendering": {
      "antialiased": true,
      "webkitFontSmoothing": "antialiased",
      "mozOsxFontSmoothing": "grayscale"
    }
  },
  "radius": {
    "base": "0.625rem",
    "sm": "calc(var(--radius) - 4px)",
    "md": "calc(var(--radius) - 2px)",
    "lg": "var(--radius)",
    "xl": "calc(var(--radius) + 4px)"
  },
  "animations": {
    "shinyText": {
      "name": "shiny-text",
      "duration": "8s",
      "iteration": "infinite"
    },
    "fadeInUp": {
      "duration": "0.8s",
      "easing": "ease-out"
    },
    "scaleIn": {
      "duration": "0.3s",
      "easing": "ease-out"
    },
    "scrollLeft": "45s linear infinite",
    "scrollUp": "50s linear infinite",
    "scrollDown": "50s linear infinite",
    "accordionDown": "accordion-down 0.2s ease-out",
    "accordionUp": "accordion-up 0.2s ease-out"
  },
  "utilityClasses": {
    "colors": {
      "textNavy": "hsl(210 68% 15%)",
      "bgNavy": "hsl(210 68% 15%)",
      "textGold": "hsl(43 74% 52%)",
      "bgGold": "hsl(43 74% 52%)"
    },
    "shadows": {
      "shadowElegant": "0 4px 20px -8px hsl(210 68% 15% / 0.2)",
      "shadowLuxury": "0 8px 40px -12px hsl(210 68% 15% / 0.3)",
      "shadowGold": "0 4px 20px -8px hsl(43 74% 52% / 0.4)"
    }
  },
  "layout": {
    "container": {
      "center": true,
      "padding": "2rem",
      "maxWidth2xl": "1400px"
    },
    "scrollbar": "hidden globally (scrollbar-width: none; -ms-overflow-style: none; ::-webkit-scrollbar { display: none })",
    "bodyOverflowX": "hidden"
  },
  "tailwindTheme": {
    "darkMode": "class",
    "borderRadius": {
      "lg": "var(--radius)",
      "md": "calc(var(--radius) - 2px)",
      "sm": "calc(var(--radius) - 4px)"
    }
  }
}
