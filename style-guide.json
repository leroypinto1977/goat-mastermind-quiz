{
  "meta": {
    "name": "GOAT Mastermind Style Guide",
    "description": "Business platform design system with navy, gold, and premium neutrals. All colors use HSL/OKLCH.",
    "version": "1.0"
  },
  "designLanguage": {
    "name": "GOAT Mastermind",
    "principles": [
      "Sophisticated color palette with navy, gold, and premium neutrals",
      "All colors MUST be HSL (or OKLCH for semantic tokens)",
      "Luxury, elegant, business-forward aesthetic",
      "Clear hierarchy: headings (Poppins), body (Inter/Raleway fallback)"
    ],
    "mood": ["Premium", "Trustworthy", "Refined", "Professional"]
  },
  "colors": {
    "brand": {
      "navy": {
        "default": { "hsl": "210 68% 15%", "hex": "#0A2140" },
        "light": { "hsl": "210 68% 25%" },
        "dark": { "hsl": "210 68% 10%" }
      },
      "gold": {
        "default": { "hsl": "43 74% 52%", "hex": "#D4AF37" },
